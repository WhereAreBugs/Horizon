# Environment Variables

# AI API Keys (configure at least one)
ANTHROPIC_API_KEY=sk-ant-xxx
OPENAI_API_KEY=sk-xxx
AZURE_OPENAI_API_KEY=xxx
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
GOOGLE_API_KEY=xxx
MINIMAX_API_KEY=xxx
DASHSCOPE_API_KEY=xxx

# WebHook Url (optional for sending notifications)
HORIZON_WEBHOOK_URL=https://xxx

# Telegram bot delivery (local callback service or Cloudflare Worker gateway)
TELEGRAM_BOT_TOKEN=123456:bot-token
TELEGRAM_CHAT_ID=-1001234567890
TELEGRAM_PUBLIC_BASE_URL=https://example.com
TELEGRAM_WEBHOOK_SECRET=choose-a-random-secret
TELEGRAM_WORKER_URL=https://horizon-telegram-bot-server.example.workers.dev
TELEGRAM_WORKER_INGEST_SECRET=choose-a-random-ingest-secret

# GitHub Token (optional but recommended for higher rate limits)
# Without token: 60 requests/hour
# With token: 5000 requests/hour
GITHUB_TOKEN=ghp_xxx

# Apify Token (required for Twitter scraping)
# Get yours at https://console.apify.com/account/integrations
APIFY_TOKEN=apify_api_xxx

# Optional: override Docker data bind mount path.
# For remote Linux deployment, keep ./data or use an absolute path such as /opt/horizon/data.
HORIZON_DATA_VOLUME=./data
